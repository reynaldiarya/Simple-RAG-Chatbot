# Server Config
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Ollama Cloud API Config
OLLAMA_API_BASE=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=ministral-3:14b-cloud
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.9

# RAG & Embeddings
EMBEDDING_MODEL=intfloat/multilingual-e5-large
SIMILARITY_THRESHOLD=0.3  # range: 0.3 - 0.6
MAX_RETRIEVED_DOCS=7 # range: 1-10
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Paths
DOCUMENTS_DIR=src/data/documents
VECTOR_DB_DIR=src/data/vector_db
