# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development # Set to "production" to disable Swagger UI (/docs, /redoc)

# Ollama API Configuration
OLLAMA_API_BASE=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=ministral-3:14b-cloud
OLLAMA_TEMPERATURE=0.1 # Range: 0.0–0.5 (lower = more factual, less hallucination)
OLLAMA_TOP_P=0.9

# RAG & Embeddings
EMBEDDING_MODEL=intfloat/multilingual-e5-large
SIMILARITY_THRESHOLD=0.3 # Range: 0.3–0.6 (cosine distance; lower = stricter relevance)
MAX_RETRIEVED_DOCS=7 # Range: 1–10
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CONTEXT_CHARS=4000 # Hard cap on total context injected into the LLM prompt
MAX_HISTORY_MESSAGES=6 # Max conversation turns passed to the LLM

# Feature Flags
CITATION_ENABLED=true # Set to "false" to disable [Source: filename] citations

# Storage Paths
DOCUMENTS_DIR=src/data/documents
VECTOR_DB_DIR=src/data/vector_db
